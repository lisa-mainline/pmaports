# Reference: <https://postmarketos.org/devicepkg>

maintainer="None None <none@none.none>"
pkgname=firmware-xiaomi-lisa
pkgver=1
pkgrel=0
pkgdesc="Firmware for Xiaomi 11 Lite 5G NE / 11 LE"
subpackages="
	$pkgname-adsp
	$pkgname-cdsp
	$pkgname-gpu
	$pkgname-ipa
	$pkgname-modem
	$pkgname-sensors
	$pkgname-vpu
	$pkgname-wpss
	"
url="https://github.com/mainlining/firmware-xiaomi-lisa"
arch="aarch64"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"
_commit="7556db82708f1d624a6684cd500b4b44e414f39b"
source="
	$pkgname-$_commit.tar.gz::$url/archive/$_commit/$pkgname-$_commit.tar.gz
	adsp.files
	cdsp.files
	gpu.files
	ipa.files
	modem.files
	sensors.files
	vpu.files
	wpss.files
"
builddir="$srcdir/$pkgname-$_commit"

package() {
	# parent package is empty
	mkdir -p "$pkgdir"
}

# Helper method for installing firmware files from a text file
install_files() {
	cd "$builddir"

	while IFS="" read -r _i || [ -n "$_i" ]; do
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname $_i)
		echo $_i
		install -Dm644 $_i "$subpkgdir/$_i"
	done < "$srcdir/$1"
}

adsp() {
	pkgdesc="Xiaomi 11 Lite 5G NE / 11 LE adsp firmware"

	mkdir "$subpkgdir"
	install_files "adsp.files"
}

cdsp() {
	pkgdesc="Xiaomi 11 Lite 5G NE / 11 LE cdsp firmware"

	mkdir "$subpkgdir"
	install_files "cdsp.files"
}

gpu() {
	pkgdesc="Xiaomi 11 Lite 5G NE / 11 LE gpu firmware"

	mkdir "$subpkgdir"
	install_files "gpu.files"
}

ipa() {
	pkgdesc="Xiaomi 11 Lite 5G NE / 11 LE ipa firmware"

	mkdir "$subpkgdir"
	install_files "ipa.files"
}

modem() {
	pkgdesc="Xiaomi 11 Lite 5G NE / 11 LE modem firmware"

	mkdir "$subpkgdir"
	install_files "modem.files"
}

sensors() {
	pkgdesc="Xiaomi 11 Lite 5G NE / 11 LE sensors firmware"

	mkdir "$subpkgdir"
	install_files "sensors.files"
}

vpu() {
	pkgdesc="Xiaomi 11 Lite 5G NE / 11 LE vpu firmware"

	mkdir "$subpkgdir"
	install_files "vpu.files"
}

wpss() {
	pkgdesc="Xiaomi 11 Lite 5G NE / 11 LE wpss firmware"

	mkdir "$subpkgdir"
	install_files "wpss.files"
}

