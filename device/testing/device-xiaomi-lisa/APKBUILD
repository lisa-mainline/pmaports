source="
	81-libssc-xiaomi-lisa.rules
	deviceinfo
	modules-initfs
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/81-libssc-xiaomi-lisa.rules -t \
		"$pkgdir"/usr/lib/udev/rules.d
}

openrc() {
	default_openrc
	mkdir -p "$subpkgdir"
}

